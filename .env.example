# Telegram-бот, у которого есть право постить в канал (создать через @BotFather)
TELEGRAM_BOT_TOKEN=

# ID канала, куда постим (например -1001234567890, бот должен быть в нём админом)
TELEGRAM_CHANNEL_ID=

# Ключ Groq (console.groq.com) — опционально: без него Блок 3 всегда
# использует нейтральный фолбэк-текст, бриф всё равно уходит
GROQ_API_KEY=

# Реф-ссылка для футера (см. §9 ТЗ), по умолчанию "[ссылка]"
REF_LINK=

# 1 = не отправлять в Telegram, а печатать собранное сообщение в консоль
# (общий для обоих ботов — какой скрипт запускаешь, тот и учитывает)
DRY_RUN=

# --- Nuvio Pulse (бриф для трейдеров, src/pulse/) — отдельный бот от брифа новичков ---

# Токен ВТОРОГО Telegram-бота (не тот же, что для новичков)
PULSE_TELEGRAM_BOT_TOKEN=

# ID канала для Pulse (сейчас — тот же канал, что у новичков; см. §11 ТЗ)
PULSE_TELEGRAM_CHANNEL_ID=

# Ссылка на LI.FI swap-виджет (integrator=nuvio) для футера, по умолчанию "[ссылка]"
PULSE_SWAP_LINK=
